# Klavity Snap — environment file (template)
# ---------------------------------------------------------------------------
# Copy to /etc/klav/klav.env on the server (chmod 600, owned by the klav user).
# Loaded by systemd (deploy/klav.service) into prototype/server.ts (Bun).
# This file holds secrets — NEVER commit the real one. Use realistic
# placeholders below; rotate procedures live in docs/security/SECRET-ROTATION.md.
# Every var here is read via process.env.* in server.ts / lib/*.ts.
# ---------------------------------------------------------------------------

# ── Core HTTP / app ────────────────────────────────────────────────────────
PORT=4317
# Public base URL used for OTP links, presigned-URL hosts, callbacks (server.ts:39).
KLAV_BASE_URL=https://klavity.in

# ── Database — Turso / libSQL (required; lib/db.ts:5-6) ─────────────────────
TURSO_DATABASE_URL=libsql://your-db-name.turso.io
TURSO_AUTH_TOKEN=CHANGEME-turso-auth-token

# ── Secret-at-rest key (required; lib/crypto.ts:8) ─────────────────────────
# AES-GCM-256 key for connector/integration secret encryption.
# MUST base64-decode to exactly 32 bytes. Generate:
#   openssl rand -base64 32
# WARNING: rotating this orphans existing ciphertext — see SECRET-ROTATION.md.
KLAV_SECRET=CHANGEME-base64-32-bytes

# ── AI — OpenRouter (required; server.ts:36, lib/trails-vision.ts:94) ──────
OPENROUTER_API_KEY=sk-or-v1-REPLACE_ME
# Optional override of the OpenRouter base host (lib/trails-vision.ts:96).
OPENROUTER_BASE=https://klavity.in
# Default model. Demo default: cheap + strong vision (~$0.002/reaction). Alts:
#   anthropic/claude-sonnet-4.6   (higher quality, ~10x cost)
#   google/gemini-2.5-flash-lite  (cheapest)
KLAV_MODEL=google/gemini-2.5-flash

# ── Email — SendGrid (OTP login + lead alerts; lib/mail.ts:3,23) ───────────
SENDGRID_API_KEY=SG.CHANGEME-sendgrid-key
# From address for all transactional mail (lib/mail.ts:4,24).
KLAV_MAIL_FROM=klav@quantana.com.au

# ── Object storage — S3-compatible (screenshots/replays; lib/s3.ts:3-8) ────
S3_ENDPOINT=https://s3.your-region.example.com
S3_REGION=us-east-1
S3_BUCKET=klavity-uploads
S3_FOLDER=uploads
AWS_ACCESS_KEY_ID=CHANGEME-s3-access-key-id
AWS_SECRET_ACCESS_KEY=CHANGEME-s3-secret-access-key

# ── Ops / admin (lib/auth.ts:30, server.ts:43) ────────────────────────────
# /opsadmin super-admin dashboard — comma-separated allowlist of ops emails.
# Empty = dashboard returns 404 to everyone.
OPS_ADMIN_EMAILS=
# Daily AI spend ceiling shown on /opsadmin (display only; OpenRouter enforces
# the real cap). server.ts:43.
OPS_DAILY_CAP_USD=50

# ── Access control / allowlists (optional; lib/auth.ts:17-18) ──────────────
# Comma-separated. If both empty, OTP login is open to any email.
KLAV_ALLOWED_DOMAINS=
KLAV_ALLOWED_EMAILS=

# ── Demo / dev toggles (leave UNSET in production) ─────────────────────────
# "1" echoes the OTP code in the API response instead of emailing — DEV ONLY
# (server.ts:41). Must be unset/0 in prod.
KLAV_DEV_SHOW_OTP=
# If set, seeds demo Trails for this project id on boot (server.ts:72-75).
TRAILS_DEMO_PROJECT_ID=
# TEST ONLY — allows loopback targets through the SSRF guard
# (lib/connectors/guard.ts:24, lib/safe-fetch.ts). NEVER set in production.
KLAV_TEST_ALLOW_LOOPBACK=

# ── Growth alerts ──────────────────────────────────────────────────────────
# Incoming-webhook URL for the #signups Slack channel. When set, every genuinely
# new user signup posts an enriched alert (geo/device/company) via
# lib/signup-alert.ts. Leave blank to disable. This is a secret — do not commit.
SLACK_SIGNUP_WEBHOOK_URL=https://hooks.slack.com/services/XXXX/XXXX/XXXX

# ── Analytics — PostHog ────────────────────────────────────────────────────
# PostHog project API key. Injected into HTML pages at serve time via
# __POSTHOG_KEY__ placeholder (server.ts htmlPage()). Leave blank to disable.
KLAV_POSTHOG_KEY=

# ── Notes ──────────────────────────────────────────────────────────────────
# Connector secrets (Plane / Jira / GitHub / Linear API tokens) are NOT env
# vars — they are entered per-project in the UI and stored AES-GCM-encrypted in
# the `connectors`/`integrations` tables using KLAV_SECRET (lib/crypto.ts,
# db.ts:220-227). Provisioning scripts may additionally read
# PROVISION_OWNER_EMAIL / PROVISION_NOTIFY_EMAIL (scripts/*), not needed at runtime.
